{
  "entities": {
    "RegistrationRequest": {
      "title": "Registration Request",
      "description": "A request from a user to register for the app.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user requesting registration."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "used"],
          "description": "The status of the registration request."
        },
        "registrationCode": {
          "type": "string",
          "description": "The 6-digit code generated by the admin for the user to complete registration."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the request was created."
        }
      },
      "required": ["email", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A registered user of the app.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user was created."
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Email": {
      "title": "Email",
      "description": "An email to be sent by the Trigger Email extension.",
      "type": "object",
      "properties": {
        "to": {
          "type": "string",
          "description": "The recipient's email address."
        },
        "message": {
          "type": "object",
          "description": "The email message content."
        }
      },
      "required": ["to", "message"]
    }
  },
  "firestore": {
    "/registration_requests/{requestId}": {
      "schema": {
        "$ref": "#/entities/RegistrationRequest"
      },
      "description": "Stores registration requests from users."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores registered users."
    },
    "/mail/{mailId}": {
      "schema": {
        "$ref": "#/entities/Email"
      },
      "description": "Stores emails to be sent by the Trigger Email extension."
    }
  }
}
